{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "aspire",
      "request": "launch",
      "name": "Aspire: Launch AppHost",
      "program": "${workspaceFolder}/services/Core/Hosts/AppHost/AppHost.csproj"
    },
    {
      "name": ".NET 10 Launch 'TenantSwitch' (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build TenantSwitch Debug",
      "program": "${workspaceFolder}/services/Core/APIs/TenantSwitch/bin/Any CPU/Debug/net10.0/TenantSwitch.dll",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "args": ["--environment \"Development\""],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": ".NET 10 Launch 'TenantSwitch' (Release)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build TenantSwitch Release",
      "program": "${workspaceFolder}/services/Core/APIs/TenantSwitch/bin/Any CPU/Release/net10.0/TenantSwitch.dll",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "args": ["--environment \"Development\""],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": ".NET 10 Launch 'AppHost' (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build AppHost Debug",
      "program": "${workspaceFolder}/services/Core/Hosts/AppHost/bin/Any CPU/Debug/net10.0/AppHost.dll",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "args": ["--environment \"Development\""],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": ".NET 10 Launch 'AppHost' (Release)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build AppHost Release",
      "program": "${workspaceFolder}/services/Core/Hosts/AppHost/bin/Any CPU/Release/net10.0/AppHost.dll",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "args": ["--environment \"Development\""],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Attach to .NET Process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
      
    }
  ]
}
